# CrowdFAQ Backend — Environment Variables
# Copy to .env and fill in values

# MongoDB
MONGODB_URI=mongodb://localhost:27017/crowdfaq

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Port
PORT=3000

# ─── Bootstrap Superadmin ───────────────────────────────────────────────────
# Set these before first deployment to create the initial superadmin.
# The bootstrap is idempotent — running again is safe.
SUPERADMIN_NAME=Super Admin
SUPERADMIN_EMAIL=admin@crowdfaq.local
SUPERADMIN_PASSWORD=changeme123

# ─── Embeddings ────────────────────────────────────────────────────────────
# Provider: "ollama" (local, free) | "mock" (dev/test only, no external deps)
EMBEDDING_PROVIDER=ollama

# Ollama settings (used when EMBEDDING_PROVIDER=ollama)
# Install: https://ollama.com — then run: ollama pull nomic-embed-text
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Minimum cosine similarity score (0–1) to consider a match valid.
# 0.75 is a sensible default; lower = more matches, higher = stricter.
AI_CONFIDENCE_THRESHOLD=0.75